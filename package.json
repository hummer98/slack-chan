{
  "name": "slack-chan",
  "version": "0.0.0",
  "description": "Slack interface for Claude — multi-workspace, default channels, persistent cache.",
  "author": "Yuji Yamamoto <yuji.yamamoto@tayorie.jp> (https://github.com/hummer98)",
  "license": "MIT",
  "type": "module",
  "main": "./src/cli/index.ts",
  "bin": {
    "slack-chan": "./src/cli/index.ts"
  },
  "exports": {
    ".": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run ./src/cli/index.ts",
    "build": "bun build --compile --target=bun ./src/cli/index.ts --outfile dist/slack-chan",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slack/web-api": "^7.15.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "nock": "^14.0.13",
    "typescript": "^6.0.3"
  }
}
