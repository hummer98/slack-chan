# Local environment (contains OAuth tokens — must never be committed)
.envrc
.env
.env.*

# cmux-team workspace (local-only orchestration state)
.team/
.worktrees/

# Build artifacts
dist/
node_modules/
.*.bun-build

# postinstall が GitHub Release から DL する native binary (npm i -g 時のみ生成)
bin/slack-chan-native
bin/slack-chan-native.tmp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Editor
.vscode/
.idea/

# npm lockfile residue (we use bun.lock; npm tooling sometimes drops this)
package-lock.json

# Claude Code session locks (project-local, ephemeral)
.claude/scheduled_tasks.lock
